<div class="homepage-layout">
  <!-- 左侧边栏：个人信息 -->
  <aside class="sidebar">
    <div class="sidebar-content">
      <!-- 头像/照片 -->
      <% if (config.sidebar && config.sidebar.avatar) { %>
        <div class="avatar-container">
          <img src="<%= url_for(config.sidebar.avatar) %>" alt="Avatar" class="avatar">
        </div>
      <% } %>
      
      <!-- 姓名和头衔 -->
      <div class="profile-header">
        <h1 class="name"><%= config.title %></h1>
      </div>
      
      <!-- 基本信息 -->
      <div class="info-list">
        <% if (config.sidebar && config.sidebar.info) { %>
          <% config.sidebar.info.forEach(function(item) { %>
            <div class="info-item">
              <% if (item.icon) { %>
                <i class="fa-solid fa-<%= item.icon %>"></i>
              <% } %>
              <span><%= item.text %></span>
            </div>
          <% }) %>
        <% } %>
      </div>
      
      <!-- 联系方式 -->
      <div class="contact-info">
        <% if (config.sidebar && config.sidebar.contact) { %>
          <% config.sidebar.contact.forEach(function(item) { %>
            <div class="contact-item">
              <% if (item.link) { %>
                <a href="<%= item.link %>" target="_blank" rel="noopener" title="<%= item.title %>">
                  <% if (item.icon) { 
                       // 品牌图标使用 fa-brands，其他使用 fa-solid
                       var iconClass = ['github', 'google', 'orcid', 'twitter', 'facebook', 'linkedin', 'researchgate'].indexOf(item.icon) >= 0 ? 'fa-brands' : 'fa-solid';
                     %>
                    <i class="<%= iconClass %> fa-<%= item.icon %>"></i>
                  <% } %>
                </a>
                <span class="contact-label"><%= item.title %></span>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
      
      <!-- 简短介绍 -->
      <% if (config.sidebar && config.sidebar.bio && config.sidebar.bio.trim() !== '') { %>
        <div class="bio">
          <%- markdown(config.sidebar.bio) %>
        </div>
      <% } %>
    </div>
  </aside>
  
  <!-- 主内容区 -->
  <main class="main-content">
    <!-- 教育背景 -->
    <% if (config.sidebar && config.sidebar.education) { %>
      <section class="content-section">
        <h2 class="section-title">🎓 教育背景</h2>
        <div class="section-content">
          <%- markdown(config.sidebar.education) %>
        </div>
      </section>
    <% } %>
    
    <!-- 研究方向 -->
    <% if (config.sidebar && config.sidebar.research_interests) { %>
      <section class="content-section">
        <h2 class="section-title">🔬 研究方向</h2>
        <div class="section-content">
          <%- markdown(config.sidebar.research_interests) %>
        </div>
      </section>
    <% } %>
  </main>
</div>
