<div class="homepage-layout">
  <!-- 左侧边栏：个人信息 -->
  <aside class="sidebar">
    <div class="sidebar-content">
      <!-- 头像/照片 -->
      <% if (theme.sidebar.avatar) { %>
        <div class="avatar-container">
          <img src="<%= url_for(theme.sidebar.avatar) %>" alt="Avatar" class="avatar">
        </div>
      <% } %>
      
      <!-- 姓名和头衔 -->
      <div class="profile-header">
        <h1 class="name"><%= config.title %></h1>
        <% if (config.subtitle) { %>
          <p class="title"><%= config.subtitle %></p>
        <% } %>
      </div>
      
      <!-- 联系方式 -->
      <div class="contact-info">
        <% if (theme.sidebar.contact) { %>
          <% theme.sidebar.contact.forEach(function(item) { %>
            <div class="contact-item">
              <% if (item.icon) { %>
                <i class="fa-solid fa-<%= item.icon %>"></i>
              <% } %>
              <% if (item.link) { %>
                <a href="<%= item.link %>" target="_blank" rel="noopener"><%= item.text %></a>
              <% } else { %>
                <span><%= item.text %></span>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
      
      <!-- 社交链接 -->
      <% if (theme.social_links) { %>
        <div class="social-links">
          <% theme.social_links.forEach(function({label, icon, link}) { %>
            <% var title = label || icon %>
            <% if (icon == 'mail') { %>
              <a class="social-icon" target="_blank" rel="noopener" href="<%- link %>" aria-label="<%- title %>" title="<%- title %>">
                <i class="fa-solid fa-envelope"></i>
              </a>
            <% } else if (icon == 'rss') { %>
              <a class="social-icon" target="_blank" rel="noopener" href="<%- link %>" aria-label="<%- title %>" title="<%- title %>">
                <i class="fa-solid fa-rss"></i>
              </a>
            <% } else { %>
              <a class="social-icon" target="_blank" rel="noopener me" href="<%- url_for(link) %>" aria-label="<%- title %>" title="<%- title %>">
                <i class="fa-brands fa-<%= icon %>"></i>
              </a>
            <% } %>
          <% }) %>
        </div>
      <% } %>
      
      <!-- 简短介绍 -->
      <% if (theme.sidebar.bio) { %>
        <div class="bio">
          <%- markdown(theme.sidebar.bio) %>
        </div>
      <% } %>
    </div>
  </aside>
  
  <!-- 主内容区 -->
  <main class="main-content">
    <!-- 研究兴趣 -->
    <% if (theme.sidebar.research_interests) { %>
      <section class="content-section">
        <h2 class="section-title">🔬 研究兴趣</h2>
        <div class="section-content">
          <%- markdown(theme.sidebar.research_interests) %>
        </div>
      </section>
    <% } %>
    
    <!-- 教育背景 -->
    <% if (theme.sidebar.education) { %>
      <section class="content-section">
        <h2 class="section-title">🎓 教育背景</h2>
        <div class="section-content">
          <%- markdown(theme.sidebar.education) %>
        </div>
      </section>
    <% } %>
    
    <!-- 技术技能 -->
    <% if (theme.sidebar.skills) { %>
      <section class="content-section">
        <h2 class="section-title">💻 技术技能</h2>
        <div class="section-content">
          <%- markdown(theme.sidebar.skills) %>
        </div>
      </section>
    <% } %>
    
    <!-- 最新动态 -->
    <% if (theme.sidebar.news) { %>
      <section class="content-section">
        <h2 class="section-title">📰 最新动态</h2>
        <div class="section-content">
          <%- markdown(theme.sidebar.news) %>
        </div>
      </section>
    <% } %>
  </main>
</div>
